{
  "manifest_version": 2,
  "name": "Delete Elements",
  "version": "dev: 1.0",

  "background": {
    "scripts": [ "background.js" ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ],

  "permissions": [ "contextMenus" ],
  "commands": {
    "undo": {
      "suggested_key": { "default": "Ctrl+Alt+Z" },
      "description": "Undos deletion of element"
    }
  }
}